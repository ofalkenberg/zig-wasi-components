package demo:httpget@0.1.0;

/// A wasi:cli `command` extended with the HTTP outgoing-handler import.
/// This is the world a Zig guest links against to make outbound HTTP
/// requests on Wasmtime.
world client {
  include wasi:cli/command@0.2.6;
  import wasi:http/outgoing-handler@0.2.6;
  import wasi:http/types@0.2.6;
}

